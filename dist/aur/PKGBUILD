# Maintainer: Juan García Longarón <glanvu@mobilife.es>
pkgname=glanvu-bin
pkgver=0.5.4
pkgrel=1
pkgdesc="Fast, keyboard-driven, cross-platform universal image viewer and converter"
arch=('x86_64')
url="https://glanvu.com"
license=('Apache-2.0')
depends=('libx11' 'libxkbcommon')
optdepends=('vulkan-icd-loader: GPU-accelerated rendering')
provides=('glanvu')
conflicts=('glanvu')
source=("$pkgname-$pkgver.tar.gz::https://github.com/glanvu/glanvu/releases/download/v$pkgver/glanvu-$pkgver-linux-x86_64.tar.gz")
sha256sums=('89784c67f149b925beac1b7208d8961485092253ad66ad2ff460eadccfcd0b52')

package() {
    install -Dm755 "glanvu-$pkgver/glanvu" "$pkgdir/usr/bin/glanvu"
    install -Dm644 "glanvu-$pkgver/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "glanvu-$pkgver/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
